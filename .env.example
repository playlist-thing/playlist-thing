# Base URL of the playlist-thing API
PUBLIC_API_BASE_URL=https://api.playlist-thing.com

# URL of OpenID/OAuth metadata for playlist-thing API
PUBLIC_API_AUTH_METADATA_URL=https://accounts.playlist-thing.com/realms/playlist-thing/.well-known/openid-configuration

# OpenID/OAuth Client ID of this frontend for playlist-thing API
# PUBLIC_API_CLIENT_ID=TODO

# URL of privacy policy
#
# If not set, links to the privacy policy will not be shown
# PUBLIC_PRIVACY_POLICY_URL=TODO

# Client ID of Spotify app
#
# https://developer.spotify.com/dashboard
PUBLIC_SPOTIFY_CLIENT_ID=TODO
